# ============================================================
#  Running Dinner Planner – Environment Variables
#  Kopieer dit bestand naar .env en vul de waarden in.
#  DEEL .env NOOIT publiek (niet in git, niet in backups).
# ============================================================

# Omgeving: development | production
NODE_ENV=development

# Poort waarop de server draait
# Dev: 3001, Prod: 3000
PORT=3001

# Geheime sleutel voor JWT-tokens (minimaal 32 willekeurige tekens)
JWT_SECRET=vervang_dit_met_een_lange_willekeurige_string_van_minstens_32_tekens

# Admin inloggegevens (hash wordt bij eerste start aangemaakt via ADMIN_PASSWORD)
ADMIN_EMAIL=admin@jouwdomein.nl
ADMIN_PASSWORD=vervang_dit_met_een_sterk_wachtwoord

# ---- Mollie ----
# Haal op via https://www.mollie.com/dashboard/developers/api-keys
# Gebruik 'test_...' voor testmodus, 'live_...' voor productie
MOLLIE_API_KEY=test_...

# Abonnementsprijs in centen (standaard 500 = €5,00)
SUBSCRIPTION_PRICE_CENTS=500

# ---- E-mail (SMTP) ----
# Gebruik bijv. Mailgun, Brevo, Gmail App Password, of eigen mailserver
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@jouwdomein.nl
SMTP_PASS=smtp_wachtwoord

# Afzenderadres voor facturen en wachtwoord-reset mails
MAIL_FROM="Running Dinner Planner <noreply@jouwdomein.nl>"

# Contactformulier: mails worden gestuurd naar dit adres
CONTACT_EMAIL=cyro@vanmalsen.net

# ---- URLs ----
# Publiek bereikbare basis-URL (zonder trailing slash)
BASE_URL=https://jouwdomein.nl

# ---- Database ----
# Pad naar de SQLite-database
DB_PATH=./data/app.db
